# Environment Variables for Production Deployment with Single URL

# Option 1: Using Vercel Proxy (Recommended for Vercel)
# Frontend will call /api and Vercel will proxy to backend
VITE_API_URL=/api

# Option 2: Direct Backend URL (if not using proxy)
# VITE_API_URL=https://cisrai-backend.onrender.com/api

# Option 3: University Server (same domain)
# VITE_API_URL=/api
